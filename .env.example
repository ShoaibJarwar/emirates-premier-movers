# --- Required ---

# Postgres connection string used by Drizzle ORM (src/db/index.ts)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Public base URL of the site, used for metadata, sitemap.xml, OG tags and JSON-LD
NEXT_PUBLIC_SITE_URL=https://www.emiratespremiermovers.ae

# --- Optional: email delivery for new inquiries (src/app/api/inquiries/route.ts) ---
# Pick ONE of the following two options. If neither is set, inquiries are still
# saved to the database but no email notification is sent.

# Option A: Resend (https://resend.com)
RESEND_API_KEY=
INQUIRY_EMAIL_TO=bookings@emiratespremiermovers.ae
INQUIRY_EMAIL_FROM=leads@emiratespremiermovers.ae

# Option B: generic webhook (Zapier, Make, n8n, etc.) that receives a JSON POST
EMAIL_WEBHOOK_URL=

# --- Optional: WhatsApp delivery for new inquiries ---
# Pick ONE of the following two options. If neither is set, inquiries are still
# saved to the database but no WhatsApp notification is sent.

# Option A: WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_INQUIRY_TO=923037224163

# Option B: generic webhook
WHATSAPP_WEBHOOK_URL=
