# --- Required ---

# Postgres connection string used by Drizzle ORM (src/db/index.ts)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Public base URL of the site, used for metadata, sitemap.xml, OG tags and JSON-LD
NEXT_PUBLIC_SITE_URL=https://www.emiratespremiermovers.ae

# --- Email notifications via EmailJS (https://www.emailjs.com) ---
# Every inquiry (quote form + contact form) is emailed to you via EmailJS, sent
# directly from the customer's browser after a successful submission.
# Sign up at emailjs.com, connect your email account as a "Service", create an
# email "Template" with variables matching src/lib/emailjs-client.ts
# ({{from_name}}, {{phone}}, {{email}}, {{service}}, {{from_location}},
# {{to_location}}, {{move_date}}, {{message}}, {{inquiry_type}}, {{to_name}}),
# then copy these three IDs from your EmailJS dashboard. All three are safe to
# expose to the browser — that's how EmailJS is designed to be used.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# If these are left blank, the site still works — inquiries are still saved to
# the database and WhatsApp-notified via Twilio below — you just won't get an email.

# --- WhatsApp notifications via Twilio (https://www.twilio.com/whatsapp) ---
# Every inquiry sends you a WhatsApp message with the lead's details via Twilio,
# sent server-side from src/app/api/inquiries/route.ts.
# Get TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN from the Twilio console.
# TWILIO_WHATSAPP_FROM is your Twilio WhatsApp sender — while testing, this is
# the Twilio Sandbox number (e.g. "whatsapp:+14155238886"); once you apply for
# and get approved for a WhatsApp Business sender, use that number instead.
# TWILIO_WHATSAPP_TO is YOUR WhatsApp number (where you want to receive leads),
# in the same "whatsapp:+<countrycode><number>" format.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+923037224163

# If these are left blank, the site still works — inquiries are still saved to
# the database and emailed via EmailJS above — you just won't get a WhatsApp alert.
